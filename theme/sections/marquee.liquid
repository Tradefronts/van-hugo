<div class="marquee bg-{{ section.settings.bg_color }} py-3 border-t border-gray-100/30">
  <div class="marquee-content">
    {% assign texts = section.settings.text_1 | append: ',' | append: section.settings.text_2 | append: ',' | append: section.settings.text_3 | append: ',' | append: section.settings.text_4 | append: ',' | append: section.settings.text_5 | append: ',' | append: section.settings.text_6 %}
    {% assign text_array = texts | split: ',' %}

    <span class="uppercase text-xs text-{{ section.settings.text_color }} font-bold">
      {% for i in (1..3) %}
        {% for item in text_array %}
          {{ item }}<span class="px-2">•</span>
        {% endfor %}
      {% endfor %}
    </span>
  </div>
</div>

{% schema %}
{
  "name": "Marquee",
  "settings": [
    {
      "type": "text",
      "id": "text_1",
      "label": "Text 1",
      "default": "fresh roast"
    },
    {
      "type": "text",
      "id": "text_2",
      "label": "Text 2",
      "default": "small batches"
    },
    {
      "type": "text",
      "id": "text_3",
      "label": "Text 3",
      "default": "bold aroma"
    },
    {
      "type": "text",
      "id": "text_4",
      "label": "Text 4",
      "default": "smooth finish"
    },
    {
      "type": "text",
      "id": "text_5",
      "label": "Text 5",
      "default": "farm to cup"
    },
    {
      "type": "text",
      "id": "text_6",
      "label": "Text 6",
      "default": "ethically sourced"
    },
    {
      "type": "select",
      "id": "text_color",
      "label": "Text Color",
      "options": [
        { "value": "white", "label": "White" },
        { "value": "black", "label": "Black" },
        { "value": "neutral-400", "label": "Gray" }
      ],
      "default": "white"
    },
    {
      "type": "select",
      "id": "bg_color",
      "label": "Background Color",
      "options": [
        { "value": "white", "label": "White" },
        { "value": "black", "label": "Black" },
        { "value": "neutral-100", "label": "Light Gray" },
        { "value": "neutral-900", "label": "Dark" }
      ],
      "default": "black"
    },
  ]
}
{% endschema %}