{% comment %} <div 
  class="max-w-4xl mx-auto px-4 py-8 text-gray-800"
  x-data="{ active: 'ingredients' }"
>

  <!-- ================= INGREDIENTS ================= -->
  <div class="border-t border-gray-300">
    
    <button
      @click="active = active === 'ingredients' ? null : 'ingredients'"
      class="w-full flex justify-between items-center py-4 text-sm tracking-wide transition-all duration-300"
      :class="active === 'ingredients' ? 'font-bold' : 'font-normal'"
    >
      INGREDIENTS
      <span 
        class="transition-transform duration-300"
        :class="active === 'ingredients' ? 'rotate-180' : ''"
      >⌄</span>
    </button>

    <div
      x-ref="ingredients"
      class="overflow-hidden transition-all duration-500 ease-in-out"
      :style="active === 'ingredients' 
        ? 'max-height: ' + $refs.ingredients.scrollHeight + 'px; opacity:1; transform: translateY(0)' 
        : 'max-height: 0px; opacity:0; transform: translateY(-10px)'"
    >
      <div class="pb-6 pt-2 flex gap-10 items-start">

        <div class="w-28">
          <img 
            src="https://upload.wikimedia.org/wikipedia/commons/4/45/A_small_cup_of_coffee.JPG"
            class="w-full object-contain"
          >
        </div>

        <div class="flex-1 text-xs text-gray-600">

          <p class="uppercase tracking-wide mb-6">
            100% Arabica coffee whole beans. No preservatives and no additives.
          </p>

          <div class="space-y-2">
            <div class="flex justify-between"><span>Fats</span><span>0g</span><span>0g</span></div>
            <div class="flex justify-between"><span>- Sat. fats</span><span>0g</span><span>0g</span></div>
            <div class="flex justify-between"><span>Carbohydrates</span><span>0g</span><span>0g</span></div>
            <div class="flex justify-between"><span>- Sugars</span><span>0g</span><span>0g</span></div>
            <div class="flex justify-between"><span>Fibres</span><span>0g</span><span>0g</span></div>
            <div class="flex justify-between"><span>Proteins</span><span>0g</span><span>0g</span></div>
            <div class="flex justify-between"><span>Salty</span><span>0g</span><span>0g</span></div>
          </div>

        </div>
      </div>
    </div>
  </div>



  <!-- REUSABLE ACCORDION TEMPLATE -->
  {% assign sections = 
    "shipping|SHIPPING POLICY,
     return|RETURN AND REFUND POLICY,
     faq1|WILL YOU GRIND MY COFFEE?,
     faq2|CAN YOU DO B2B OR BULK ORDERS?,
     faq3|WHAT IS THE SHELF LIFE?,
     faq4|CAN I RETURN THIS?,
     faq5|IS THERE CHICORY ADDED?" | split: "," %}

  {% for item in sections %}
    {% assign parts = item | strip | split: "|" %}
    {% assign key = parts[0] %}
    {% assign title = parts[1] %}

    <div class="border-t border-gray-300">

      <button
        @click="active = active === '{{ key }}' ? null : '{{ key }}'"
        class="w-full flex justify-between items-center py-4 text-sm transition-all duration-300"
        :class="active === '{{ key }}' ? 'font-bold' : 'font-normal'"
      >
        {{ title }}
        <span 
          class="transition-transform duration-300"
          :class="active === '{{ key }}' ? 'rotate-180' : ''"
        >⌄</span>
      </button>

      <div
        x-ref="{{ key }}"
        class="overflow-hidden transition-all duration-500 ease-in-out"
        :style="active === '{{ key }}'
          ? 'max-height: ' + $refs['{{ key }}'].scrollHeight + 'px; opacity:1; transform: translateY(0)'
          : 'max-height: 0px; opacity:0; transform: translateY(-10px)'"
      >
        <div class="pb-6 pt-2 text-xs text-gray-600">
          This is placeholder content for {{ title }}.
        </div>
      </div>

    </div>

  {% endfor %}

</div>

<script defer src="https://cdn.jsdelivr.net/npm/alpinejs@3.x.x/dist/cdn.min.js"></script> {% endcomment %}
