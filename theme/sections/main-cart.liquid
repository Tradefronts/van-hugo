<div class="max-w-7xl mx-auto px-6 py-12">
  <h1 class="text-3xl font-bold tracking-widest uppercase mb-8">Shopping Cart</h1>
  {% if cart.item_count > 0 %}
    <div class="grid md:grid-cols-3 gap-8">
      <!-- LEFT: Cart Items -->
      <div class="md:col-span-2">
        <form action="/cart" method="post" id="cart-form">
          {% for item in cart.items %}
            <div class="flex gap-4 border-b py-6" id="cart-item-{{ item.key }}">
              <div class="w-24 h-24 flex-shrink-0">
                
                {% if item.image %}
                  <img 
                    src="{{ item.image | img_url: '200x200' }}" 
                    alt="{{ item.title }}"
                    class="w-full h-full object-cover rounded"
                    loading="lazy"
                    height=""
                    width=""
                  >
                {% endif %}
              </div>
              <div class="flex-grow">
                <a href="{{ item.url }}" class="font-semibold text-lg hover:underline">
                  {{ item.product.title }}
                </a>
                                {% unless item.variant.title contains 'Default' %}
                  <p class="text-sm text-gray-600 mt-1">{{ item.variant.title }}</p>
                {% endunless %}
                <p class="text-gray-900 font-medium mt-2">{{ item.price | money }}</p>
                <div class="flex items-center gap-3 mt-3">
                  <label class="text-sm font-medium">Qty:</label>
                                    <button 
                    type="button" 
                    class="w-8 h-8 border border-gray-300 rounded hover:bg-gray-100 transition"
                    onclick="decreaseQuantity('{{ item.key }}', {{ item.quantity }})"
                    aria-label="Decrease quantity"
                  >
                    −
                  </button>
                  <input 
                    type="number" 
                    name="updates[{{ item.key }}]" 
                    id="quantity-{{ item.key }}"
                    value="{{ item.quantity }}" 
                    min="1"
                    class="w-12 text-center border border-gray-300 rounded py-1"
                    onchange="updateCartItem('{{ item.key }}', this.value)"
                  >
                  <button 
                    type="button" 
                    class="w-8 h-8 border border-gray-300 rounded hover:bg-gray-100 transition"
                    onclick="increaseQuantity('{{ item.key }}', {{ item.quantity }})"
                    aria-label="Increase quantity"
                  >
                    +
                  </button>
                                    <button
                    type="button"
                    class="text-red-600 text-sm hover:underline ml-4 font-medium"
                    onclick="removeItem('{{ item.key }}')"
                  >
                    Remove
                  </button>
                </div>
              </div>
            </div>
          {% endfor %}
        </form>
      </div>

      <!-- RIGHT: Order Summary -->
      <div class="md:col-span-1">
        <div class="bg-gray-50 p-6 rounded-lg sticky top-24">
          <h2 class="text-xl font-bold mb-4 uppercase tracking-wider">Order Summary</h2>
          
          <div class="flex justify-between mb-3">
            <span class="text-gray-600">Sub Total</span>
            <span class="font-semibold" id="cart-subtotal">{{ cart.total_price | money }}</span>
          </div>
          <div class="flex justify-between mb-3">
            <span class="text-gray-600">Items</span>
            <span id="cart-count">{{ cart.item_count }}</span>
          </div>
          <div class="flex justify-between mb-6 text-lg font-bold">
            <span>Total</span>
            <span id="cart-total">{{ cart.total_price | money }}</span>
          </div>
          <form action="/cart" method="post">
            <button 
              type="submit" 
              name="checkout"
              class="w-full bg-black text-white py-4 uppercase tracking-widest font-semibold hover:bg-gray-800 transition"
            >
              Proceed to Checkout
            </button>
          </form>
          <a 
            href="/collections/all" 
            class="block text-center mt-4 text-sm underline hover:no-underline"
          >
            Continue Shopping
          </a>
        </div>
      </div>
    </div>

  {% else %}
    <div class="text-center py-12">
      <svg class="w-24 h-24 mx-auto text-gray-300 mb-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 11V7a4 4 0 00-8 0v4M5 9h14l1 12H4L5 9z"/>
      </svg>
      <h2 class="text-2xl font-bold mb-4">Your cart is empty</h2>
      <p class="text-gray-600 mb-6">Add some products to get started!</p>
      <a 
        href="/collections/all" 
        class="inline-block bg-black text-white px-8 py-3 uppercase tracking-wider hover:bg-gray-800 transition"
      >
        Continue Shopping
      </a>
    </div>
  {% endif %}
</div>

<script>
  function removeItem(itemKey) {
    if (confirm('Are you sure you want to remove this item?')) {
      updateCartItem(itemKey, 0);
    }
  }
  function increaseQuantity(itemKey, currentQty) {
    const newQty = currentQty + 1;
    updateCartItem(itemKey, newQty);
  }

  function decreaseQuantity(itemKey, currentQty) {
    if (currentQty > 1) {
      const newQty = currentQty - 1;
      updateCartItem(itemKey, newQty);
    }
  }
  function updateCartItem(itemKey, quantity) {
    const itemElement = document.getElementById(`cart-item-${itemKey}`);
    if (itemElement) {
      itemElement.style.opacity = '0.5';
    }
    fetch('/cart/change.js', {
      method: 'POST',
      headers: {
        'Content-Type': 'application/json',
      },
      body: JSON.stringify({
        id: itemKey,
        quantity: parseInt(quantity)
      })
    })
    .then(response => {
      if (!response.ok) {
        throw new Error('Network response was not ok');
      }
      return response.json();
    })
    .then(data => {
      console.log('Cart updated:', data);
            window.location.reload();
    })
    .catch(error => {
      console.error('Error updating cart:', error);
      alert('Error updating cart. Please try again.');
            if (itemElement) {
        itemElement.style.opacity = '1';
      }
    });
  }

  function updateCartSummary(cartData) {
        const subtotalInCents = cartData.total_price;
    const subtotalInRupees = (subtotalInCents / 100).toFixed(2);
    document.getElementById('cart-subtotal').textContent = 'Rs. ' + subtotalInRupees;
        document.getElementById('cart-total').textContent = 'Rs. ' + subtotalInRupees;
        document.getElementById('cart-count').textContent = cartData.item_count;
  }
</script>

{% schema %}
{
  "name": "Cart",
  "settings": [
    {
      "type": "checkbox",
      "id": "show_vendor",
      "label": "Show product vendor",
      "default": false
    }
  ]
}
{% endschema %}
