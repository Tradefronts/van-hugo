<div
  class="relative w-full overflow-hidden min-h-screen"
>
  <div class="absolute inset-0">
    {% if section.settings.background_image %}
      <img
        src="{{ section.settings.background_image | image_url: width: 2000 }}"
        alt="Banner image"
        class="w-full h-full object-cover object-top md:object-fill absolute inset-0"
        loading="lazy"
        height=""
        width=""
      >
    {% else %}
      <img
        src="{{ 'banner.png' | asset_url }}"
        alt="Banner image"
        class="w-full h-full object-cover object-top md:object-fill absolute inset-0"
        loading="lazy"
        height=""
        width=""
      >
    {% endif %}
  </div>
  <div
    class="
      absolute  z-10 h-full flex items-center md:left-1/2 md:-translate-x-1/2 "
  >
    <div class="max-w-xl md:px-12 px-10   text-white font-inter  tracking-tighter flex flex-col items-center justify-center">
      {% if section.settings.subtext != blank %}
        <p class="text-xl mb-6 font-extralight">
          {{ section.settings.subtext }}
        </p>
      {% endif %}

      {% if section.settings.button_label != blank %}
        <a
          href="{{ section.settings.button_link }}"
          class="inline-block md:px-12 px-10 md:py-3.5 py-3.5 text-sm capitalize bg-[#434343] font-extralight md:rounded-none rounded-full"
        >
          {{ section.settings.button_label }}
        </a>
      {% endif %}
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Image Banner",
  "settings": [
    {
      "type": "image_picker",
      "id": "background_image",
      "label": "Background Image"
    },
    {
      "type": "range",
      "id": "section_height",
      "label": "Section Height (vh)",
      "min": 40,
      "max": 100,
      "step": 5,
      "default": 90
    },
    {
      "type": "range",
      "id": "overlay_opacity",
      "label": "Overlay Opacity (%)",
      "min": 0,
      "max": 80,
      "step": 5,
      "default": 40
    },
    {
      "type": "select",
      "id": "content_alignment",
      "label": "Content Alignment",
      "options": [
        { "value": "left", "label": "Left" },
        { "value": "center", "label": "Center" },
        { "value": "right", "label": "Right" }
      ],
      "default": "center"
    },
    {
      "type": "textarea",
      "id": "subtext",
      "label": "Subtext",
      "default": "“Every bean has a moment where its character is revealed. We stop there - never before, never after.”"
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button Label",
      "default": "Learn More"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button Link"
    }
  ]
}
{% endschema %}
