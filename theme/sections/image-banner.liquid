<section
  class="relative w-full overflow-hidden"
  style="height: {{ section.settings.section_height }}vh;"
>

  <!-- Background Image -->
  <div class="absolute inset-0">
    <img
      src="{% if section.settings.background_image != blank %}
              {{ section.settings.background_image | image_url: width: 2000 }}
            {% else %}
              {{ 'banner.png' | asset_url }}
            {% endif %}"
      alt="{{ section.settings.heading | escape }}"
      class="w-full h-full object-cover"
      loading="lazy"
      height=""
      width=""
    >
  </div>

  <!-- Overlay -->
  <div
    class="absolute inset-0 bg-black"
    style="opacity: {{ section.settings.overlay_opacity | divided_by: 100.0 }};"
  ></div>

  <!-- Content -->
  <div class="relative z-10 h-full flex items-center
    {% case section.settings.content_alignment %}
      {% when 'left' %} justify-start text-left
      {% when 'center' %} justify-center text-center
      {% when 'right' %} justify-end text-right
    {% endcase %}
  ">
    <div class="max-w-2xl px-6 md:px-12 text-white">

      {% if section.settings.subtext != blank %}
        <p class="text-lg mb-6 font-inter  font-extralight tracking-wide">
          {{ section.settings.subtext }}
        </p>
      {% endif %}

      {% if section.settings.button_label != blank %}
        <a
          href="{{ section.settings.button_link }}"
          class="inline-block  px-10 py-3.5 text-sm capitalize bg-[#434343]"
        >
          {{ section.settings.button_label }}
        </a>
      {% endif %}

    </div>
  </div>

</section>

{% schema %}
{
  "name": "Image Banner",
  "settings": [
    {
      "type": "image_picker",
      "id": "background_image",
      "label": "Background Image"
    },
    {
      "type": "range",
      "id": "section_height",
      "label": "Section Height (vh)",
      "min": 40,
      "max": 100,
      "step": 5,
      "default": 90
    },
    {
      "type": "range",
      "id": "overlay_opacity",
      "label": "Overlay Opacity (%)",
      "min": 0,
      "max": 80,
      "step": 5,
      "default": 40
    },
    {
      "type": "select",
      "id": "content_alignment",
      "label": "Content Alignment",
      "options": [
        { "value": "left", "label": "Left" },
        { "value": "center", "label": "Center" },
        { "value": "right", "label": "Right" }
      ],
      "default": "center"
    },
    {
      "type": "textarea",
      "id": "subtext",
      "label": "Subtext",
      "default": "“Every bean has a moment where its character is revealed. We stop there - never before, never after.”"
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button Label",
      "default": "Learn More"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button Link"
    }
  ],
  "presets": [
    {
      "name": "Image Banner"
    }
  ]
}
{% endschema %}