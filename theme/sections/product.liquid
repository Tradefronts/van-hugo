<div class="min-h-screen ">
  <div class="flex md:flex-row flex-col xl:gap-10 md:gap-7 gap-0 px-8 ">
    <div class="xl:w-7/12 md:w-1/2 w-full xl:py-0 md:py-16 py-5 md:sticky top-10 md:self-start xl:min-h-dvh md:border-r md:border-b border-[#D7D7D7] flex md:items-center items-start md:justify-center">
      <div
        id="imageSlider"
        class="w-full h-full overflow-x-auto snap-x snap-mandatory no-scrollbar flex"
        style="max-height: clamp(300px, 60vw, 80vh);"
      >
        {% for image in product.images %}
          <div class="w-full flex-shrink-0 flex items-center justify-center px-4 md:px-6 xl:px-10">
            <img
              src="{{ image | image_url: width: 800 }}"
              alt="{{ product.title }}"
              class="w-full h-full object-contain max-h-[clamp(280px,55vw,75vh)] lg:-translate-x-8 -translate-x-5"
              loading="lazy"
              width="800"
              height="800"
            >
          </div>
        {% endfor %}
      </div>
    </div>
    <div class="xl:w-5/12 md:w-1/2 w-full lg:space-y-8 space-y-5 font-inter xl:pr-12 md:pt-5 lg:pt-0  ">
      <form
        id="product-form"
        method="post"
        action="/cart/add"
        enctype="multipart/form-data"
        class="lg:space-y-8 space-y-5 "
      >
        <input type="hidden" name="id" id="variant-id" value="{{ product.selected_or_first_available_variant.id }}">
        <div class="space-y-4">
          <div class="">
            <span class="block uppercase md:text-3xl text-lg font-semibold tracking-tighter">{{ product.title }}</span>
            <span class="block md:text-lg text-sm font-semibold tracking-tighter md:-mt-1.5 -mt-1">
              {{ product.metafields.coffee.bean }}
            </span>
          </div>
          <div class="text-[#8D8D8D] md:text-lg tracking-tighter text-xs" style="line-height: 1.2;">
            {{ product.description | replace: '<p>', '<p style="margin-bottom: 0.60rem;">' }}
          </div>
        </div>

        <div class="xl:mr-14 md:mr-0 sm:mr-20 md:space-y-8 space-y-5">
          {% unless product.has_only_default_variant %}
            <div class="pack-size">
              <p class="font-bold md:text-lg text-sm tracking-tight uppercase">pack size</p>
              {% for option in product.options_with_values %}
                {% if option.name == 'Weight' %}
                  <div class="grid grid-cols-3 md:gap-3 gap-2 mt-4">
                    {% for value in option.values %}
                      <label class="cursor-pointer w-full">
                        <input
                          type="radio"
                          name="options[{{ option.name }}]"
                          value="{{ value }}"
                          class="hidden peer"
                          {% if option.selected_value == value %}
                            checked
                          {% endif %}
                        >
                        <span class="tracking-tighter block w-full text-center md:py-3 py-1.5 md:text-lg text-sm md:border-2 border border-black peer-checked:bg-black peer-checked:text-white transition font-bold">
                          {{ value }}
                        </span>
                      </label>
                    {% endfor %}
                  </div>
                {% endif %}
              {% endfor %}
            </div>
          {% endunless %}

          {% unless product.has_only_default_variant %}
            <div class="grind-size">
              <p class="font-bold md:text-lg text-sm tracking-tight uppercase">Grind Size</p>
              {% for option in product.options_with_values %}
                {% if option.name == 'Grind size' %}
                  <div class="grid lg:grid-cols-4 sm:grid-cols-3 grid-cols-4 md:gap-3 gap-1 mt-4">
                    {% for value in option.values %}
                      <label class="cursor-pointer">
                        <input
                          type="radio"
                          name="options[{{ option.name }}]"
                          value="{{ value }}"
                          class="hidden peer"
                          {% if option.selected_value == value %}
                            checked
                          {% endif %}
                        >
                        <div class="flex items-center justify-center rounded-md border-2 border-transparent font-medium peer-checked:border-black peer-checked:font-semibold transition md:h-20 h-12">
                          <p class="uppercase md:text-sm text-[0.6rem] text-center leading-tight">
                            {% assign words = value | split: ' ' %}
                            {% for word in words %}
                              {{ word -}}
                              <br>
                            {% endfor %}
                          </p>
                        </div>
                      </label>
                    {% endfor %}
                  </div>
                {% endif %}
              {% endfor %}
            </div>
          {% endunless %}
          <div class="space-y-2">
            {% assign variant = product.selected_or_first_available_variant %}
            <div id="price-wrapper" class="flex items-center gap-3 mb-4">
              <span class="md:text-3xl text-2xl font-bold  tracking-tighter">
                ₹{{ variant.price | divided_by: 100 }}
              </span>
              {% if variant.compare_at_price > variant.price %}
                <span class="text-[#ABABAB] md:text-2xl text-lg md:font-bold font-semibold line-through tracking-tighter">
                  ₹{{ variant.compare_at_price | divided_by: 100 }}
                </span>
                <span class="text-[#900000] text-lg md:font-bold font-semibold md:text-2xl tracking-tighter">
                  {{
                    variant.compare_at_price
                    | minus: variant.price
                    | times: 100
                    | divided_by: variant.compare_at_price
                  -}}
                  % OFF
                </span>
              {% endif %}
            </div>
            <div class="space-y-2">
              <div class="grid lg:grid-cols-3 sm:grid-cols-2 grid-cols-3 gap-2">
                <div class="border-2 md:py-3 py-1.5 border-black flex items-center justify-between ">
                  <button type="button" id="decreaseQty" class="md:px-4 px-2 text-lg font-bold">−</button>
                  <input
                    type="number"
                    id="qtyInput"
                    name="quantity"
                    value="1"
                    min="1"
                    class="md:w-10 w-8 text-center outline-none font-semibold bg-transparent"
                  >
                  <button type="button" id="increaseQty" class="md:px-4 px-2 text-lg font-bold">+</button>
                </div>
                <button
                  type="button"
                  id="add-to-cart-btn"
                  onclick="handleAddToCart(event)"
                  class="font-medium uppercase border-2 md:py-3 py-1.5 lg:col-span-2 sm:col-span-1 col-span-2 border-black md:text-base text-sm"
                >
                  Add to cart
                </button>
              </div>
              <button
                type="submit"
                name="add"
                class="w-full md:py-4 py-3 uppercase bg-black text-white md:text-base text-sm"
              >
                buy now
              </button>
            </div>
          </div>
          <div class="">
            <h3 class="font-bold md:text-lg tracking-tight uppercase mb-2">Shipping</h3>
            <div class="flex items-center justify-between mt-6 border-b-2 border-black pb-3">
              <div class="flex items-center gap-3 w-full">
                <img
                  id="iconDelivery"
                  src="{{ 'locationPin-icon.svg' | asset_url }}"
                  width=""
                  height=""
                  class="h-10 md:w-8 w-6"
                  alt=""
                >
                <input
                  type="text"
                  id="pincodeInput"
                  placeholder="ENTER DELIVERY PINCODE"
                  class="leading-tight w-full outline-none md:text-lg text-sm font-medium placeholder-black tracking-tighter"
                >
              </div>
              <button
                type="button"
                id="checkBtn"
                class="text-[#4052BA] font-semibold md:text-lg text-sm ml-4 tracking-tighter"
              >
                CHECK
              </button>
            </div>

            <div class="mt-2 md:text-sm text-xs font-medium hidden  tracking-tighter" id="deliveryBox">
              <p>
                <span class="font-medium" id="deliveryDateText">DELIVERY BY - </span>
                |
                <span>FREE <span class="line-through">₹120</span></span>
              </p>
              <p class="text-gray-500 mt-1 font-medium" id="codText">IF ORDERED BEFORE 6PM TODAY</p>
            </div>

            <div class="flex items-center justify-between md:my-8 my-5 text-xs hidden" id="timeline">
              <div class="flex flex-col items-center text-center font-semibold tracking-tighter">
                <img
                  id="iconPurchased"
                  src="{{ 'blackCart-icon.svg' | asset_url }}"
                  width=""
                  height=""
                  class="md:h-10 md:w-8 h-6 w-5"
                  alt=""
                >
                <p class="md:mt-2 -mt-0.5 md:text-xs text-[0.6rem]">PURCHASED</p>
                <span id="purchasedDate" class="md:text-xs text-[0.6rem]"></span>
              </div>
              <div id="line1" class="flex-1 h-[2px] bg-gray-300 mx-2"></div>
              <div class="flex flex-col items-center text-center font-semibold tracking-tighter">
                <img
                  id="iconShipped"
                  src="{{ 'shipping-icon.svg' | asset_url }}"
                  width=""
                  height=""
                  class="md:h-10 md:w-8 h-6 w-5"
                  alt=""
                >
                <p class="md:mt-2 -mt-0.5 md:text-xs text-[0.6rem]">SHIPPED</p>
                <span id="shippedDate" class="md:text-xs text-[0.6rem]"></span>
              </div>
              <div id="line2" class="flex-1 h-[2px] bg-gray-300 mx-2"></div>
              <div class="flex flex-col items-center text-center font-semibold tracking-tighter">
                <img
                  id="iconDelivery"
                  src="{{ 'locationPin-icon.svg' | asset_url }}"
                  width=""
                  height=""
                  class="md:h-10 md:w-8 h-6 w-5"
                  alt=""
                >
                <p class="md:mt-2 -mt-0.5 md:text-xs text-[0.6rem]">DELIVERY</p>
                <span id="deliveredDate" class="md:text-xs text-[0.6rem]"></span>
              </div>
            </div>
          </div>
          {% render 'product-accordion' %}
        </div>
      </form>
    </div>
  </div>
</div>

<script>
  document.addEventListener("DOMContentLoaded", function () {
    const variants = {{ product.variants | json }};
    const priceWrapper = document.getElementById("price-wrapper");
    const variantIdInput = document.getElementById("variant-id");
    const radios = document.querySelectorAll('input[name^="options"]');

    function getSelectedVariant() {
      const selectedOptions = [];
      document.querySelectorAll('input[name^="options"]:checked')
        .forEach(input => selectedOptions.push(input.value));
      return variants.find(v =>
        v.options.every((opt, i) => opt === selectedOptions[i])
      );
    }

    radios.forEach(radio => {
      radio.addEventListener("change", function () {
        const matched = getSelectedVariant();
        if (!matched) return;
        variantIdInput.value = matched.id;
        let html = `
          <span class="md:text-3xl text-2xl font-bold tracking-tight">
            ₹${Math.round(matched.price / 100)}
          </span>
        `;
        if (matched.compare_at_price && matched.compare_at_price > matched.price) {
          const pct = Math.round(
            (matched.compare_at_price - matched.price) * 100 / matched.compare_at_price
          );
          html += `
            <span class="text-[#ABABAB] md:text-2xl text-lg md:font-bold font-semibold line-through tracking-tight">
              ₹${Math.round(matched.compare_at_price / 100)}
            </span>
            <span class="text-[#900000] text-lg md:font-bold font-semibold md:text-2xl tracking-tight">
              ${pct}% OFF
            </span>
          `;
        }
        priceWrapper.innerHTML = html;
      });
    });
  });

  document.addEventListener("DOMContentLoaded", function () {
    const qtyInput = document.getElementById("qtyInput");

    document.getElementById("increaseQty").addEventListener("click", () => {
      qtyInput.value = parseInt(qtyInput.value) + 1;
    });

    document.getElementById("decreaseQty").addEventListener("click", () => {
      if (parseInt(qtyInput.value) > 1) {
        qtyInput.value = parseInt(qtyInput.value) - 1;
      }
    });
  });
  document.addEventListener("DOMContentLoaded", function () {
    const checkBtn = document.getElementById("checkBtn");
    const pincodeInput = document.getElementById("pincodeInput");
    if (!checkBtn) return;

    const mapping = {
      "110001": { days: 7, cod: true },
      "400001": { days: 3, cod: true },
      "781005": { days: 5, cod: false },
      "783380": { days: 1, cod: false }
    };

    checkBtn.addEventListener("click", function () {
      const pincode = pincodeInput.value.trim();
      if (!mapping[pincode]) {
        alert("Delivery not available in this area.");
        return;
      }

      const { days } = mapping[pincode];
      const today = new Date();
      const shippedStart = new Date(today); shippedStart.setDate(today.getDate() + 1);
      const shippedEnd   = new Date(today); shippedEnd.setDate(today.getDate() + days - 1);
      const deliveryDate = new Date(today); deliveryDate.setDate(today.getDate() + days);

      const shortDate = d => d.toLocaleDateString("en-US", { month: "short", day: "2-digit" }).toUpperCase();
      const fullDate  = d => d.toLocaleDateString("en-US", { weekday: "long", month: "long", day: "numeric" }).toUpperCase();

      document.getElementById("deliveryDateText").innerText = "DELIVERY BY " + fullDate(deliveryDate);
      document.getElementById("deliveryBox").classList.remove("hidden");
      document.getElementById("purchasedDate").innerText  = shortDate(today);
      document.getElementById("shippedDate").innerText    = shortDate(shippedStart) + " - " + shortDate(shippedEnd);
      document.getElementById("deliveredDate").innerText  = shortDate(deliveryDate);
      document.getElementById("timeline").classList.remove("hidden");
      document.getElementById("iconPurchased").classList.remove("opacity-50");
      setTimeout(() => {
        document.getElementById("iconShipped").classList.remove("opacity-50");
        document.getElementById("line1").classList.replace("bg-gray-300", "bg-blue-500");
      }, 400);
      setTimeout(() => {
        document.getElementById("iconDelivery").classList.remove("opacity-50");
        document.getElementById("line2").classList.replace("bg-gray-300", "bg-blue-500");
      }, 800);
    });
  });
  function handleAddToCart(event) {
    event.preventDefault();

    const variantId = document.getElementById("variant-id").value;
    const quantity  = parseInt(document.getElementById("qtyInput").value) || 1;
    const button    = document.getElementById("add-to-cart-btn");

    if (!variantId) {
      alert("Please select a variant.");
      return;
    }

    const originalText = button.innerHTML;
    button.innerHTML = "Adding...";
    button.disabled  = true;

    fetch('/cart/add.js', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ id: variantId, quantity: quantity })
    })
    .then(response => {
      if (!response.ok) throw new Error(`HTTP ${response.status}`);
      return response.json();
    })
    .then(() => {
      openCartDrawer(); 
    })
    .catch(error => {
      console.error('Add to cart failed:', error);
      alert('Failed to add item to cart. Please try again.');
    })
    .finally(() => {
      button.innerHTML = originalText;
      button.disabled  = false;
    });
  }
</script>

{% schema %}
{
  "name": "Product"
}
{% endschema %}
