<div>
  <div class="relative">
    <div class="h-screen w-full bg-neutral-700 relative">
      {% if section.settings.background != blank %}
        <img
          class="h-full w-full object-cover"
          height=""
          width=""
          src="{{ section.settings.background | image_url: width: 1500 }}"
          alt="banner_image"
        >
      {% else %}
        <img
          class="h-full w-full object-cover"
          src="{{'hero-img.png' | asset_url }}"
          alt="banner_image"
          height=""
          width=""
        >
      {% endif %}
    </div>

<div class="absolute inset-0 flex flex-col items-center gap-2 text-white {{ section.settings.horizontal_position }}" style="justify-content: center; margin-top: -173px;">  
      <span class="text-2xl text-center playfair-display-400">{{ section.settings.heading }}</span>
      <a href="{{ section.settings.button_link }}" class="border text-center text-white text-[8px] px-6 py-2 tracking-widest uppercase font-semibold {{ section.settings.button_radius }}">
        {{ section.settings.Btn_text }}
      </a>
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Hero Section",
  "settings": [
    {
      "type": "image_picker",
      "id": "background",
      "label": "Image"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Coffee that feels like home."
    },
    {
      "type": "text",
      "id": "Btn_text",
      "label": "Button Name",
      "default": "Explore"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button Link"
    },
    {
      "type": "select",
      "id": "button_radius",
      "label": "Border Radius",
      "options": [
        { "value": "rounded-none", "label": "None" },
        { "value": "rounded-md", "label": "Medium" },
        { "value": "rounded-full", "label": "Full" }
      ],
      "default": "rounded-full"
    },
    {
      "type": "select",
      "id": "horizontal_position",
      "label": "Content Horizontal Position",
      "options": [
        { "value": "items-start text-left pl-10", "label": "Left" },
        { "value": "items-center text-center", "label": "Center" },
        { "value": "items-end text-right pr-10", "label": "Right" }
      ],
      "default": "items-center text-center"
    }
  ],
  "presets": [{ "name": "Hero Section" }]
}
{% endschema %}