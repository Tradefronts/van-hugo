<div class="relative min-h-screen w-full">

  {% if section.settings.background != blank %}
    <img
      src="{{ section.settings.background | image_url: width: 1500 }}"
      {% comment %} class="w-full h-full object-cover" {% endcomment %}
            class="absolute inset-0 w-full h-full object-cover"

      alt="Hero Image"
      height=""
      width=""
    >
  {% else %}
    <img
      src="{{ 'hero-img.png' | asset_url }}"
      {% comment %} class="w-full h-full object-cover" {% endcomment %}
            class="absolute inset-0 w-full h-full object-cover"

      alt="Hero Image"
      width=""
      height=""
    >
  {% endif %}

  <div class="absolute inset-0 flex flex-col items-center justify-center text-white text-center md:gap-2 gap-3 md:px-6 px-20 sm:mb-5 md:-translate-y-16 -translate-y-24">

    <h1 class="sm:text-4xl md:text-3xl text-2xl  playfair-display-100 tracking-tight font-extralight">
      {{ section.settings.heading }}
    </h1>

    <a
      href="{{ section.settings.button_link }}"
      class="border px-5 py-1.5 text-[0.5rem] uppercase {{ section.settings.button_radius }}"
    >
      {{ section.settings.Btn_text }}
    </a>

  </div>

</div>

{% schema %}
{
  "name": "Hero Section",
  "settings": [
    {
      "type": "image_picker",
      "id": "background",
      "label": "Image"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Coffee that feels like home."
    },
    {
      "type": "text",
      "id": "Btn_text",
      "label": "Button Name",
      "default": "Explore"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button Link"
    },
    {
      "type": "select",
      "id": "button_radius",
      "label": "Border Radius",
      "options": [
        { "value": "rounded-none", "label": "None" },
        { "value": "rounded-md", "label": "Medium" },
        { "value": "rounded-full", "label": "Full" }
      ],
      "default": "rounded-full"
    }
  ],
  "presets": [
    { "name": "Hero Section" }
  ]
}
{% endschema %}