<nav
  id="navbar"
  class="fixed z-50 w-full mobile-inactive h-14 bg-black text-white"
>
  <div class="flex justify-between w-full h-14 items-center px-8 transition duration-300">
    <div class="flex">
      <ul class="flex gap-10 text-xs scale-75">
        <li class="uppercase tracking-widest">A</li>
        <li class="uppercase tracking-widest">B</li>
        <li class="uppercase tracking-widest">C</li>
      </ul>
      <img
        onclick="toggleMenu()"
        src="{{ 'hamburger.svg' | asset_url }}"
        width="20"
        height="20"
        class="invert inline-block xl:hidden"
        alt="Menu"
      >
    </div>
    <div class="flex pr-12">
      <a href="{{ routes.root_url }}">
        {% if settings.logo != blank %}
          <img
            src="{{ settings.logo | image_url: width: 200 }}"
            alt="{{ shop.name }} logo"
            width="100"
            height="50"
            class="h-auto"
          >
        {% else %}
          <span class="text-lg font-semibold">{{ shop.name }}</span>
        {% endif %}
      </a>
    </div>
    <div class="flex">
      <ul class="flex gap-10 text-xs scale-75">
        <li class="uppercase tracking-widest">X</li>
        <li class="uppercase tracking-widest">Y</li>
        <li class="uppercase tracking-widest">Z</li>
      </ul>
    </div>
  </div>
</nav>

{% schema %}
{
  "name": "Navigation",
  "settings": [
    {
      "type": "collection",
      "id": "collection_1",
      "label": "Collection 1"
    }
  ]
}
{% endschema %}
