<div class="max-w-7xl mx-auto px-6  grid grid-col-1 md:grid-cols-3 gap-10  py-20 ">
  <div>
    <div class="space-y-5">
      <h4 class="font-bold tracking-wider uppercase text-sm mb-2">Contact an advisor</h4>
      <span class="text-neutral-500 leading-none"
        >Please contact CHANEL Client Care Department on Monday - Sunday, 10 a.m. - 8 p.m. (except National Holidays)
        via email at clientcare.india@chanel.com or by calling 0008000504445</span
      >
    </div>
  </div>

  <div class="space-y-3">
    <div class="space-y-5">
      <h4 class="font-bold tracking-wider uppercase text-sm mb-2 ">Find a store</h4>
      <span>Enter a location to find the closest CHANEL stores</span>
    </div>
    <div class="">
        <input placeholder="City or Zip code " class="w-3/4 border-b-2 outline-none border-gray-300 bg-transparent py-1 placeholder:text-gray-500 placeholder:text-sm">
    </div>
  </div>

  <div class="space-y-3">
    <div class="space-y-5">
      <h4 class="font-bold tracking-wider uppercase text-sm mb-2">Newsletter</h4>
      <span>Subscribe to receive news from CHANEL </span>
    </div>
    <button>Subscribe</button>
  </div>
</div>

{% schema %}
{
  "name": "Get In Touch",
  "settings": [
    {
      "type": "text",
      "id": "contact_heading",
      "label": "Contact heading",
      "default": "Contact an advisor"
    },
    {
      "type": "textarea",
      "id": "contact_description",
      "label": "Contact description",
      "default": "Please contact CHANEL Client Care Department on Monday - Sunday, 10 a.m. - 8 p.m. (except National Holidays) via email at clientcare.india@chanel.com or by calling 0008000504445"
    },
    {
      "type": "text",
      "id": "store_heading",
      "label": "Find a store heading",
      "default": "Find a store"
    },
    {
      "type": "textarea",
      "id": "store_description",
      "label": "Find a store description",
      "default": "Enter a location to find the closest CHANEL stores"
    },
    {
      "type": "text",
      "id": "newsletter_heading",
      "label": "Newsletter heading",
      "default": "Newsletter"
    },
    {
      "type": "textarea",
      "id": "newsletter_description",
      "label": "Newsletter description",
      "default": "Subscribe to receive news from CHANEL"
    }
  ]
}
{% endschema %}
