<style>
  #shopify-section-{{ section.id }} .section-grid {
    display: grid;
    grid-template-columns: repeat({{ section.settings.mobile_columns }}, minmax(0,1fr));
  }
  @media (min-width: 720px) {
    #shopify-section-{{ section.id }} .section-grid {
      grid-template-columns: repeat({{ section.settings.desktop_columns }}, minmax(0,1fr));
    }
  }
</style>

<div class="w-full font-inter md:pt-16 pt-5">
  <div class="px-8"
  >
    <h1
      class="text-2xl md:text-3xl uppercase tracking-tighter mb-2 font-semibold"
    >
      {{ collection.title }}
    </h1>
  </div>

  <form
    id="FacetFiltersForm"
    method="get"
    class="mb-5 flex items-center gap-6 px-8"
    x-data="{ active: null }"
  >
    <span class="text-sm font-medium whitespace-nowrap">Filter:</span>

    <div class="flex items-center gap-8">
      {% for filter in collection.filters %}
        <div class="relative">
          <button
            type="button"
            @click.stop="
                  active === {{ forloop.index }}
              ? active = null
              : active = {{ forloop.index }}
            "
            class="flex items-center gap-2 text-sm px-3 py-1 rounded transition-colors duration-200"
            :class="
              active === {{ forloop.index }}
              ? ' text-black'
              : ' text-gray-500'
            "
          >
            <span>{{ filter.label }}</span>

            <svg
              class="w-4 h-4 transition-transform duration-200"
              :class="{ 'rotate-180': active === {{ forloop.index }} }"
              fill="none"
              stroke="currentColor"
              viewBox="0 0 24 24"
            >
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/>
            </svg>
          </button>

          <div
            x-show="active === {{ forloop.index }}"
            x-transition
            class="absolute left-0 top-full mt-2 bg-white border shadow-lg p-4 w-64 z-50"
          >
            {% case filter.type %}
              {% when 'list' %}
                <div class="space-y-2 max-h-60 overflow-y-auto">
                  {% for value in filter.values %}
                    <label class="flex items-center justify-between text-sm cursor-pointer">
                      <div class="flex items-center gap-2">
                        <input
                          type="radio"
                          name="{{ value.param_name }}"
                          value="{{ value.value }}"
                          {% if value.active %}
                            checked
                          {% endif %}
                          class="border-gray-400"
                          onchange="this.form.submit()"
                        >
                        <span>{{ value.label }}</span>
                      </div>
                      <span class="text-gray-400 text-xs">
                        {{ value.count }}
                      </span>
                    </label>
                  {% endfor %}
                </div>

              {% when 'price_range' %}
                <div class="flex gap-2">
                  <input
                    type="number"
                    name="{{ filter.min_value.param_name }}"
                    value="{% if filter.min_value.value %}{{ filter.min_value.value | divided_by: 100 }}{% endif %}"
                    min="0"
                    placeholder="Min"
                    class="w-1/2 border p-2 text-sm"
                    onchange="this.form.submit()"
                  >

                  <input
                    type="number"
                    name="{{ filter.max_value.param_name }}"
                    value="{% if filter.max_value.value %}{{ filter.max_value.value | divided_by: 100 }}{% endif %}"
                    min="0"
                    placeholder="Max"
                    class="w-1/2 border p-2 text-sm"
                    onchange="this.form.submit()"
                  >
                </div>
            {% endcase %}
          </div>
        </div>
      {% endfor %}
    </div>
  </form>

  <div class="grid grid-cols-2 ">
    {% for product in collection.products %}
      <div class="relative border-b border-r border-[#00000040] flex flex-col">
          <a href="{{ product.url }}">
          <div class="absolute md:top-0 right-0 bottom-0">
            <button
              onclick="event.preventDefault(); event.stopPropagation(); openVariationDrawer('{{ product.handle }}')"
              class="bg-black lg:h-14 lg:w-14 md:w-10 md:h-10 h-7 w-7 flex items-center justify-center md:p-1.5 p-2"
              aria-label="Select options for {{ product.title }}"
            >
              <img src="{{ 'add-icon.svg' | asset_url }}" alt="Add" width="20" height="20">
            </button>
          </div>

          <div class=" flex items-center justify-center lg:pb-20 md:pb-7 pb-5 lg:pt-36 pt-10 md:pt-20">
           
            <div class=" block lg:h-96 lg:w-72 md:h-80 md:w-64 w-32 h-40">
              {% if product.featured_image %}
                <img
                  src="{{ product.featured_image | image_url: width: 600 }}"
                  alt="{{ product.title }}"
                  class="h-full w-full object-cover md:-translate-x-5 -translate-x-4"
                  width="100"
                  height="100"
                >
              {% else %}
                {{ 'product-1' | placeholder_svg_tag: 'h-full w-full object-contain opacity-20' }}
              {% endif %}
            </div>
          </div>
          <div class="">
            <div class="flex lg:flex-row flex-col items-center justify-between lg:px-14 md:px-8 pb-5  mt-auto">
              <div class="flex flex-col lg:items-start lg:justify-start items-center justify-center">
                <h3 class="uppercase lg:text-2xl text-sm font-semibold md:mb-1 leading-tight tracking-tighter">
                  {{ product.title }}
                </h3>
                <div>
                  <span class="lg:text-sm text-xs tracking-tighter uppercase font-semibold lg:block hidden">
                    {{ product.metafields.coffee.flavor }}
                  </span>
                  <span class="lg:text-sm text-[10px] tracking-tighter block md:text-[#7C7C7C] text-black uppercase font-medium">
                    {{- product.metafields.coffee.bean -}}
                  </span>
                </div>
              </div>

              <div class="md:text-lg text-[0.6rem] md:font-semibold font-medium mt-1 md:mt-0">
                {% if product.variants.size > 0 %}
                  {% assign first_variant = product.variants.first %}
                  <span class="tracking-tighter">₹{{ first_variant.price | divided_by: 100 | round }} | </span>
                  <span class="text-[#7C7C7C] uppercase tracking-tighter">{{ first_variant.option1 }}</span>
                {% endif %}
              </div>
            </div>
          </div>
        </a>
      </div>
    {% endfor %}
  </div>
</div>

{% schema %}
{
  "name": "Collection Products",
  "settings": [
    {
      "type": "range",
      "id": "header_font_size",
      "label": "Header Font Size",
      "min": 16,
      "max": 60,
      "step": 1,
      "default": 36,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "header_letter_spacing",
      "label": "Header Letter Spacing",
      "min": 0,
      "max": 10,
      "step": 0.5,
      "default": 2,
      "unit": "px"
    },
    {
      "type": "select",
      "id": "header_font_weight",
      "label": "Header Font Weight",
      "default": "600",
      "options": [
        { "value": "400", "label": "Normal" },
        { "value": "500", "label": "Medium" },
        { "value": "600", "label": "Semibold" },
        { "value": "700", "label": "Bold" }
      ]
    },
    {
      "type": "range",
      "id": "header_margin_bottom",
      "label": "Header Margin Bottom",
      "min": 0,
      "max": 100,
      "step": 5,
      "default": 20,
      "unit": "px"
    },

    {
      "type": "select",
      "id": "mobile_columns",
      "label": "Mobile Columns",
      "default": "2",
      "options": [
        { "value": "1", "label": "1 Column" },
        { "value": "2", "label": "2 Columns" }
      ]
    },
    {
      "type": "select",
      "id": "desktop_columns",
      "label": "Desktop Columns",
      "default": "3",
      "options": [
        { "value": "2", "label": "2 Columns" },
        { "value": "3", "label": "3 Columns" },
        { "value": "4", "label": "4 Columns" }
      ]
    }
  ]
}
{% endschema %}
